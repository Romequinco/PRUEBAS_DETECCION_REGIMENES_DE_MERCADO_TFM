# .env.example — plantilla de credenciales del proyecto.
# Copiar a .env y rellenar con tus valores. El .env real NUNCA se commitea
# (está en .gitignore); este .example sí se versiona como referencia del equipo.
#
#   cp .env.example .env      # y edita los valores

# FRED API key (St. Louis Fed). Gratuita: https://fred.stlouisfed.org/docs/api/api_key.html
# Necesaria para descargar crédito (HY/IG OAS), curva de tipos, índices de estrés
# (NFCI/STLFSI) y macro. Sin ella, esas series de FRED no se descargan.
FRED_API_KEY=your_fred_api_key_here
