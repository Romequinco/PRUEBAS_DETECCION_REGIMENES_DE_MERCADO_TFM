\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Reparto del podio por eje. La cobertura sist\'emica se da separada por grupo de ventana (nunca mezclada).\relax }}{9}{table.caption.13}\protected@file@percent }
\newlabel{tab:podio}{{6}{9}{Reparto del podio por eje. La cobertura sist\'emica se da separada por grupo de ventana (nunca mezclada).\relax }{table.caption.13}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}Hallazgos metodol\'ogicos transversales}{9}{section.6}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(a) El \emph  {look-ahead} compraba suavidad, no acierto.}{9}{section*.14}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(b) El Viterbi por bloque era menos causal y menos estable que el filtrado forward.}{9}{section*.15}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(c) La t-Student est\'a bien especificada; el gaussiano no.}{9}{section*.16}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Bondad de ajuste de los modelos generativos. El BIC s\'olo es comparable sobre las mismas \emph  {features}: el contraste limpio es D4 frente a D8 (ambos HMM, mismo conjunto de 7 \emph  {features} puente).\relax }}{9}{table.caption.17}\protected@file@percent }
\newlabel{tab:bic}{{7}{9}{Bondad de ajuste de los modelos generativos. El BIC s\'olo es comparable sobre las mismas \emph {features}: el contraste limpio es D4 frente a D8 (ambos HMM, mismo conjunto de 7 \emph {features} puente).\relax }{table.caption.17}{}}
\@writefile{toc}{\contentsline {paragraph}{(d) El \emph  {taper tantrum} de 2013 es un punto ciego universal.}{10}{section*.18}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(e) La complejidad no se paga: parsimonia validada.}{10}{section*.19}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{(f) Dos arreglos imprescindibles del marco de evaluaci\'on.}{10}{section*.20}\protected@file@percent }
