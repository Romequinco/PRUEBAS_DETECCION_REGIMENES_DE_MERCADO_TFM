\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Tabla maestra}{5}{subsection.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Tabla maestra resumida (valores \emph  {verbatim} de \texttt  {results/metrics_master_final.csv}). \emph  {switching}: conmutaciones por d\'ia (bajo = persistente); \emph  {dur.}: duraci\'on media de r\'egimen en d\'ias; \emph  {FA global}: tasa global de falsa alarma; BIC s\'olo en modelos generativos.\relax }}{5}{table.caption.5}\protected@file@percent }
\newlabel{tab:maestra}{{2}{5}{Tabla maestra resumida (valores \emph {verbatim} de \code {results/metrics_master_final.csv}). \emph {switching}: conmutaciones por d\'ia (bajo = persistente); \emph {dur.}: duraci\'on media de r\'egimen en d\'ias; \emph {FA global}: tasa global de falsa alarma; BIC s\'olo en modelos generativos.\relax }{table.caption.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Cobertura de crisis: estricta y estr\'es agregado}{5}{subsection.5.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Cobertura de crisis con definici\'on \textbf  {estricta} (proporci\'on de d\'ias en crisis por ventana). \emph  {NaN} = ventana fuera del rango OOS del detector (no se penaliza lo que no se pudo ver).\relax }}{6}{table.caption.6}\protected@file@percent }
\newlabel{tab:cobestricta}{{3}{6}{Cobertura de crisis con definici\'on \textbf {estricta} (proporci\'on de d\'ias en crisis por ventana). \emph {NaN} = ventana fuera del rango OOS del detector (no se penaliza lo que no se pudo ver).\relax }{table.caption.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Cobertura con \textbf  {estr\'es agregado} (correcci\'on $+$ crisis) para los tres multi-estado; en los binarios coincide con la estricta. El criterio relajado eleva mucho la cobertura de crisis lentas de D8 y D12.\relax }}{6}{table.caption.7}\protected@file@percent }
\newlabel{tab:estres}{{4}{6}{Cobertura con \textbf {estr\'es agregado} (correcci\'on $+$ crisis) para los tres multi-estado; en los binarios coincide con la estricta. El criterio relajado eleva mucho la cobertura de crisis lentas de D8 y D12.\relax }{table.caption.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Especificidad en las ventanas-trampa (proporci\'on de d\'ias ``encendido''; bajo = mejor). Se muestran la versi\'on estricta y la de estr\'es agregado. \emph  {NaN} = trampa fuera del OOS del detector.\relax }}{6}{table.caption.8}\protected@file@percent }
\newlabel{tab:especificidad}{{5}{6}{Especificidad en las ventanas-trampa (proporci\'on de d\'ias ``encendido''; bajo = mejor). Se muestran la versi\'on estricta y la de estr\'es agregado. \emph {NaN} = trampa fuera del OOS del detector.\relax }{table.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Los planos de \emph  {trade-off}}{6}{subsection.5.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Plano sensibilidad $\leftrightarrow $ especificidad. Eje X: especificidad $=1-$ media de falsa alarma en 2013/2018. El color/forma codifica el grupo de ventana; D11/D12 son exploratorio-negativos.\relax }}{7}{figure.caption.9}\protected@file@percent }
\newlabel{fig:sensesp}{{4}{7}{Plano sensibilidad $\leftrightarrow $ especificidad. Eje X: especificidad $=1-$ media de falsa alarma en 2013/2018. El color/forma codifica el grupo de ventana; D11/D12 son exploratorio-negativos.\relax }{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Plano persistencia (duraci\'on media, eje log) $\leftrightarrow $ sensibilidad. D3/D12 \emph  {flickean}; D7 y las reglas son muy persistentes.\relax }}{7}{figure.caption.9}\protected@file@percent }
\newlabel{fig:persens}{{5}{7}{Plano persistencia (duraci\'on media, eje log) $\leftrightarrow $ sensibilidad. D3/D12 \emph {flickean}; D7 y las reglas son muy persistentes.\relax }{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces BIC de los modelos generativos (menor = mejor). \textbf  {Aviso}: s\'olo es estrictamente comparable sobre las mismas \emph  {features} (D4 frente a D8). Gris = negativo.\relax }}{7}{figure.caption.10}\protected@file@percent }
\newlabel{fig:bic}{{6}{7}{BIC de los modelos generativos (menor = mejor). \textbf {Aviso}: s\'olo es estrictamente comparable sobre las mismas \emph {features} (D4 frente a D8). Gris = negativo.\relax }{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Multi-estado: cobertura estricta frente a estr\'es agregado en COVID 2020 e Inflaci\'on 2022. Lectura honesta de los dos lados del \emph  {trade-off}.\relax }}{7}{figure.caption.10}\protected@file@percent }
\newlabel{fig:estres}{{7}{7}{Multi-estado: cobertura estricta frente a estr\'es agregado en COVID 2020 e Inflaci\'on 2022. Lectura honesta de los dos lados del \emph {trade-off}.\relax }{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Ranking por eje (1 = mejor; m\'as oscuro = mejor rango). \textbf  {Corrige el defecto} de la versi\'on previa: la cobertura se separa por ventana ---la GFC 2008 s\'olo ranquea entre los seis detectores de ventana larga, COVID 2020 entre los doce--- y las filas se agrupan por grupo de ventana. El lead/lag medio est\'a censurado (ver Secci\'on~\ref  {sec:limitaciones}).\relax }}{8}{figure.caption.11}\protected@file@percent }
\newlabel{fig:rank}{{8}{8}{Ranking por eje (1 = mejor; m\'as oscuro = mejor rango). \textbf {Corrige el defecto} de la versi\'on previa: la cobertura se separa por ventana ---la GFC 2008 s\'olo ranquea entre los seis detectores de ventana larga, COVID 2020 entre los doce--- y las filas se agrupan por grupo de ventana. El lead/lag medio est\'a censurado (ver Secci\'on~\ref {sec:limitaciones}).\relax }{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Lead/lag por evento (d\'ias de \emph  {trading}; negativo = la se\~nal sostenida anticipa el suelo del \emph  {drawdown}). El asterisco y el borde discontinuo marcan los valores \textbf  {censurados} en $\pm 252$ d\'ias: la se\~nal ya estaba activa al inicio de la ventana de b\'usqueda, de modo que no es anticipaci\'on genuina sino sesgo \emph  {always-on}. Filas separadas por grupo de ventana.\relax }}{8}{figure.caption.12}\protected@file@percent }
\newlabel{fig:leadlag}{{9}{8}{Lead/lag por evento (d\'ias de \emph {trading}; negativo = la se\~nal sostenida anticipa el suelo del \emph {drawdown}). El asterisco y el borde discontinuo marcan los valores \textbf {censurados} en $\pm 252$ d\'ias: la se\~nal ya estaba activa al inicio de la ventana de b\'usqueda, de modo que no es anticipaci\'on genuina sino sesgo \emph {always-on}. Filas separadas por grupo de ventana.\relax }{figure.caption.12}{}}
